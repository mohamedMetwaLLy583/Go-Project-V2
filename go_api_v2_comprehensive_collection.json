{
	"info": {
		"_postman_id": "go-project-v2-full",
		"name": "Go Project V2 - Comprehensive API",
		"description": "The complete API collection for Go Project V2 - Includes Customer and Driver flows.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "01. Constants & Data",
			"item": [
				{ "name": "Get Countries", "request": { "method": "GET", "url": "{{baseUrl}}/constants/countries" } },
				{ "name": "Get Cities", "request": { "method": "GET", "url": "{{baseUrl}}/constants/cities" } },
				{ "name": "Get Neighborhoods", "request": { "method": "GET", "url": "{{baseUrl}}/constants/neighborhoods" } },
				{ "name": "Get Nationalities", "request": { "method": "GET", "url": "{{baseUrl}}/constants/nationalities" } },
				{ "name": "Get Regions", "request": { "method": "GET", "url": "{{baseUrl}}/constants/regions" } },
				{ "name": "Get Days", "request": { "method": "GET", "url": "{{baseUrl}}/constants/days" } }
			]
		},
		{
			"name": "02. Authentication & OTP",
			"item": [
				{ "name": "Send OTP", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"phone\": \"0500000001\"}" }, "url": "{{baseUrl}}/otp/send-otp" } },
				{ "name": "Verify OTP", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"phone\": \"0500000001\", \"otp\": \"1234\"}" }, "url": "{{baseUrl}}/otp/verify-otp" } },
				{ "name": "Login", "request": { "method": "POST", "body": { "mode": "raw", "raw": "{\"email\": \"admin@admin.com\", \"password\": \"password\"}" }, "url": "{{baseUrl}}/auth/login" } },
				{ "name": "Register User", "request": { "method": "POST", "body": { "mode": "formdata", "formdata": [{"key": "name", "value": "User Test"}, {"key": "email", "value": "user@test.com"}, {"key": "password", "value": "12345678"}, {"key": "phone", "value": "0511111111"}, {"key": "age", "value": "25"}, {"key": "nationality_id", "value": "1"}] }, "url": "{{baseUrl}}/auth/register/user" } },
				{ "name": "Register Driver", "request": { "method": "POST", "body": { "mode": "formdata", "formdata": [{"key": "name", "value": "Driver Test"}, {"key": "email", "value": "driver@test.com"}, {"key": "password", "value": "12345678"}, {"key": "phone", "value": "0522222222"}, {"key": "age", "value": "30"}, {"key": "nationality_id", "value": "1"}] }, "url": "{{baseUrl}}/auth/register/driver" } }
			]
		},
		{
			"name": "03. Order Flow (Customer Side)",
			"item": [
				{ "name": "Create Comprehensive Order", "request": { "auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{token}}"}] }, "method": "POST", "body": { "mode": "raw", "raw": "{\n    \"nationality_id\": 1,\n    \"salary\": 2000,\n    \"shift_type\": \"fixed\",\n    \"trip_type\": \"round_trip\",\n    \"delivery_days\": [\"Saturday\", \"Sunday\"],\n    \"start_date\": \"2024-06-01\",\n    \"is_urgent\": true,\n    \"passengers\": [\n        {\n            \"name\": \"الراكب الأول\",\n            \"pickup_location\": \"نقطة الانطلاق نصياً\",\n            \"pickup_neighborhood\": \"حي الملز\",\n            \"pickup_location_type\": \"home\",\n            \"pickup_lat\": \"24.6789\",\n            \"pickup_lng\": \"46.7123\",\n            \"return_location\": \"نقطة الوصول نصياً\",\n            \"return_neighborhood\": \"حي العليا\",\n            \"return_location_type\": \"work\",\n            \"return_lat\": \"24.7123\",\n            \"return_lng\": \"46.6789\",\n            \"driver_arrival_time\": \"07:00\",\n            \"work_start_time\": \"08:00\"\n        }\n    ]\n}" }, "url": "{{baseUrl}}/orders/store" } },
				{ "name": "My Orders List", "request": { "auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{token}}"}] }, "method": "GET", "url": "{{baseUrl}}/orders" } },
				{ "name": "See Driver Proposals", "request": { "auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{token}}"}] }, "method": "GET", "url": "{{baseUrl}}/orders/1/applications" } },
				{ "name": "Accept Driver Offer", "request": { "auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{token}}"}] }, "method": "POST", "url": "{{baseUrl}}/orders/applications/1/accept" } }
			]
		},
		{
			"name": "04. Driver Flow",
			"item": [
				{ "name": "List Available Drivers", "request": { "method": "GET", "url": "{{baseUrl}}/drivers" } },
				{ "name": "Apply to Order (Bid)", "request": { "auth": { "type": "bearer", "bearer": [{"key": "token", "value": "{{token}}"}] }, "method": "POST", "url": "{{baseUrl}}/orders/1/apply" } }
			]
		}
	],
	"variable": [
		{ "key": "baseUrl", "value": "https://go.sdevelopment.tech/api" },
		{ "key": "token", "value": "" }
	]
}
